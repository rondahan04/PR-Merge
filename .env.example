# ─── OpenAI ────────────────────────────────────────────────────────────────────
# Server-side only. NEVER use NEXT_PUBLIC_OPENAI_API_KEY — that embeds the key
# in the client JS bundle and exposes it to every browser.
OPENAI_API_KEY=sk-...

# Model to use for snippet generation (defaults to gpt-4.5 if unset).
# Other options: gpt-4o, gpt-4o-mini
# OPENAI_MODEL=gpt-4.5

# ─── API auth secret ────────────────────────────────────────────────────────────
# Both values must match. The client sends NEXT_PUBLIC_API_SECRET as the
# X-Api-Secret header; the server validates it against API_SECRET.
# Generate a pair with: openssl rand -hex 32
NEXT_PUBLIC_API_SECRET=change-me-before-deploy
API_SECRET=change-me-before-deploy

# ─── Rate limiting ──────────────────────────────────────────────────────────────
# Optional. Max requests per window, per IP (defaults: 20 req / 60 000 ms).
# API_RATE_LIMIT=20
# API_RATE_WINDOW_MS=60000
